<%- layout("layouts/BoilerPlate.ejs") %>


<link rel="stylesheet" href="/stylesheets/star.css">  
    

<div class="container mb-5">
    <h1 class="text-center mb-3"> <%= camp.title %> </h1>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <img src="<%= camp.image %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title card-header"> <%= camp.title %></h5>
                    

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><%= camp.description %></li>
                        <li class="list-group-item"><%= camp.location %></li>
                        <li class="list-group-item"><%= camp.price %></li>
                        <li class="list-group-item"> Created by <%= camp.author.username%>   </li>

                    </ul>

                    <% if(user && camp.author.equals(user)){ %>
                    
                    <a href="/campgrounds/<%= camp._id %>/edit" class="btn btn-warning">EDIT</a>
                    <form class="d-inline" action="/campgrounds/<%= camp.id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger">DELETE</button>
                    </form>
                    <% } %>
                    <a href="/campgrounds" class="btn btn-info">All campgrounds</a>
                </div>
            </div>

        </div>
        <div class="col-md-6">
            <div class="row">
                <% if(user){ %>
                <h4>Add a review</h3>
                <form action="/campgrounds/<%= camp._id %>/review" method="post" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="body" class="form-label"></label>
                        <textarea name="review[body]" id="body" cols="10" rows="5" class="form-control" required></textarea>
                        <div class="valid-feedback">Looks nice</div>
                    </div>
                    <div class="mb-3">
                        <p>Rating</p>
                        <fieldset class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <button class="btn btn-success">Add </button>


                </form>
                <% } %>
            </div>
            <div class="row">
                <% if(camp.reviews.length > 0 ){ %>
                    <h4 class="text-center">Reviews</h4>
                <% } %>
                <% for(let r of camp.reviews){ %>
                    <div class="card mb-2">
                        
                        <div class="card-body">
                            <h5 class="card-title"><%= r.author.username %></h5>
                            <p class="starability-result" data-rating="<%= r.rating %>">
                                Rated: <%= r.rating %> stars
                            </p>
                            <p class="card-text"> <%= r.body %> </p>
                            <% if(user && r.author.equals(user._id)) {%>
                                <form action="/campgrounds/<%= camp._id %>/review/<%= r._id %>?_method=DELETE" method="post">
                                    <button class="btn btn-danger">delete</button>
                                </form>
                            <% } %>
                            
                        </div>
                    </div>






                    
                    <% } %>
            </div>
        </div>
    </div>

</div>