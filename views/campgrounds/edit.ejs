<%- layout("layouts/BoilerPlate.ejs") %>


<div class="container">
    <h1 class="text-center">Edit Campground</h1>
    <div class="row">
        <div class="col-md-6">
            

                        
                <form   action="/campgrounds/<%=camp._id%>?_method=PUT" method="post" class="needs-validation" enctype="multipart/form-data" novalidate>
                    <div>
                        <div class="mb-3">
                            <label class="form-label" for="title">Title</label>
                            <input class="form-control" type="text" id="title" name="campground[title]" value="<%= camp.title %> " required>
                            <div class="valid-feedback">Not bad</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="description">Description</label>
                            <input class="form-control" type="text" id="description" name="campground[description]" value="<%= camp.description%>" required>
                            <div class="valid-feedback">Not bad</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="location">location</label>
                            <input class="form-control" type="text" id="location" name="campground[location]" value="<%= camp.location %> " required>
                            <div class="valid-feedback">Not bad</div>
                        </div>
                        <div class="mb-3">
                            <input type="file" name="image" multiple>
                            <!-- <label class="form-label" for="image">Image url</label>
                            <input class="form-control" type="text" id="image" name="campground[image]" value="<%= camp.image %>" required>
                            <div class="valid-feedback">Not bad</div> -->
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="price">Price</label>
                            <input class="form-control" type="number" id="price" name="campground[price]" value="<%= camp.price %>" required>
                            <div class="valid-feedback">Not bad</div>
                        </div>
                        <div class="mb-3">
                            <% camp.images.forEach((e,i)=>{  %>
                                <img src="<%=e.thumbnail  %>" class="img-thumbnail"  alt="..."> 
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="<%= `image-${i}` %>" name="deleteImages[]" value="<%= e.filename %>">
                                    <label class="form-check-label" for="<%=`image-${i}` %>">
                                        Delete ?
                                    </label>
                                </div>

                            <% })   %>
                        </div>
                    </div>
                    

                    <button class="btn btn-info">UPDATE</button>
                    <a href="/campgrounds" class="btn btn-primary">All Camps</a>
                </form>
            

        </div>
    </div>
</div>

